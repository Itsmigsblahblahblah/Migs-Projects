rules_version = '2';

service cloud.firestore {

  match /databases/{database}/documents {

    // Farmers Collection - UPDATED to allow admin to read and delete farmers
    match /farmers/{userId} {
      // Allow farmers to read/write their own data
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Allow anyone to create farmer profile
      allow create: if request.auth != null;
      
      // Allow admin to read all farmers
      allow read: if request.auth != null && 
                     request.auth.token.email == 'admin@majayjay.farm';
      
      // Allow admin to delete farmer accounts
      allow delete: if request.auth != null && 
                       request.auth.token.email == 'admin@majayjay.farm';
    }
    
    // Allow authenticated users to read/write farm reports
    match /farmReports/{reportId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && 
        (resource.data.userId == request.auth.uid || 
         request.auth.token.email == 'admin@majayjay.farm');
    }
    
    // Farmer Crops Collection
    match /farmerCrops/{cropId} {
      // Allow farmers to read only their own crops
      allow read: if request.auth != null && 
                     resource.data.userId == request.auth.uid;
      
      // Allow farmers to create crops with their own userId
      allow create: if request.auth != null && 
                       request.resource.data.userId == request.auth.uid;
      
      // Allow farmers to update only their own crops
      allow update: if request.auth != null && 
                       resource.data.userId == request.auth.uid;
      
      // Allow farmers to delete only their own crops
      allow delete: if request.auth != null && 
                       resource.data.userId == request.auth.uid;
      
      // Allow admin to read all crops
      allow read: if request.auth != null && 
                     request.auth.token.email == 'admin@majayjay.farm';
      
      // Allow admin to delete all crops (for account deletion)
      allow delete: if request.auth != null && 
                       request.auth.token.email == 'admin@majayjay.farm';
    }
    
    // Allow read access to rules (for admin)
    match /rules/{ruleId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
